# ============================================================
# .env.example — Variables de entorno para RINO USAS Backend
# Copia este archivo como ".env" y completa los valores reales.
# NUNCA subas el archivo .env real a un repositorio público.
# ============================================================

# ─── Servidor ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Frontend (para CORS) ───────────────────────────────────
# URL donde corre el frontend de React (Vite dev server)
FRONTEND_URL=http://localhost:5173

# ─── Correo receptor de pedidos ─────────────────────────────
# Este correo recibirá todas las solicitudes de cotización
EMAIL_RECEPTOR=rinousas@gmail.com

# ─── Configuración SMTP ─────────────────────────────────────
# Para Gmail: habilitar "Contraseñas de aplicación" en tu cuenta Google
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Cuenta desde la cual se envían los correos
SMTP_USER=rinousas@gmail.com

# Contraseña de aplicación de Gmail (NO la contraseña normal de Gmail)
# Ejemplo: abcd efgh ijkl mnop
SMTP_PASS=tu_contrasena_de_aplicacion_aqui

# ─── WhatsApp ────────────────────────────────────────────────
# URL del enlace de WhatsApp (no se usa en backend pero se documenta aquí)
WHATSAPP_URL=https://w.app/mxcysq
